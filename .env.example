# Configuration for the temporal-agent-sandbox service.
#
# Copy this file to `.env` before running:
#
#   cp .env.example .env
#
# All runtime configuration is externalized via environment variables.
# No operational values are hardcoded in the application.
# -----------------------------------------------------------------------------

# =============================================================================
# API
# =============================================================================

# Static bearer token used for the local demo.
# Replace this value before running.
# Production deployments should source secrets from a secure secret manager
# (e.g. AWS Secrets Manager, HashiCorp Vault, or Kubernetes Secrets).
API_BEARER_TOKEN=replace-with-your-token

# Reject oversized requests well below Temporal's gRPC payload limit (~4 MiB).
MAX_TASK_BYTES=8192
MAX_CODE_BYTES=262144


# =============================================================================
# Temporal
# =============================================================================

TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=agent-pipeline

# Overall workflow timeout.
WORKFLOW_RUN_TIMEOUT_S=300


# =============================================================================
# Activity Policies
#
# Retry and timeout behavior is centralized in:
# app/temporal/policies.py
# =============================================================================

AGENT_START_TO_CLOSE_S=10
SANDBOX_START_TO_CLOSE_S=60
SANDBOX_HEARTBEAT_S=10

# Allows for worker cold-starts before scheduling the first activity.
SCHEDULE_TO_START_S=30

MAX_ATTEMPTS=3


# =============================================================================
# Sandbox
# =============================================================================

# Runtime used for executing untrusted code.
#
# Local development:
#   runsc (gVisor) — recommended
#
# Production:
#   Firecracker microVMs (implemented behind the SandboxRunner interface)
#
# runc is supported only as a documented lower-security fallback.
SANDBOX_RUNTIME=runsc

SANDBOX_IMAGE=sandbox-runner:pinned

# Resource limits applied to every sandbox execution.
SANDBOX_CPUS=1.0
SANDBOX_MEMORY_MB=256
SANDBOX_PIDS=128

# Maximum execution time before the sandbox is forcefully terminated.
SANDBOX_WALL_CLOCK_S=30

# Maximum captured stdout/stderr.
SANDBOX_OUTPUT_MAX_BYTES=1048576

SANDBOX_TMPFS_MB=64
SANDBOX_NOFILE=256

# Optional seccomp profile applied by the sandbox runtime.
# Leave blank to use the runtime default.
SANDBOX_SECCOMP_PATH=

# Shared staging directory used by the worker and sandbox containers (DooD).
# Docker Compose configures this automatically.
# Leave blank to use the system temporary directory.
SANDBOX_SHARE_DIR=


# =============================================================================
# Observability
# =============================================================================

OTEL_SERVICE_NAME=agent-sandbox
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Include activity inputs and outputs in traces.
#
# Secure default: false
#
# Enable only for local debugging since untrusted program output will be sent
# to the trace backend.
TRACE_PAYLOADS=false

LOG_LEVEL=INFO